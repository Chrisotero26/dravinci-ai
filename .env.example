# ================================================
# DRAVINCI AI — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ================================================

# App
NEXT_PUBLIC_APP_URL=https://dravinci.ai

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_ANNUAL_PRICE_ID=price_your_annual_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# ElevenLabs (TTS — Premium feature)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ================================================
# CHARACTER VOICE IDs from ElevenLabs Dashboard
# ================================================
# To get voice IDs:
# 1. Go to elevenlabs.io
# 2. Add/clone voices that match each character
# 3. Copy the voice ID from the dashboard
# 4. Replace PLACEHOLDER_*_VOICE_ID in data/characters.js
# ================================================
